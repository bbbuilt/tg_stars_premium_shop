# Fragment Stars Demo Bot
# Скопируйте файл:
# cp .env.example .env

# 1. Telegram bot
# Пример: BOT_TOKEN=<bot_id>:<bot_secret_from_botfather>
BOT_TOKEN=

# Пример: ADMIN_USER_ID=123456789
# Можно оставить пустым, если уведомления админу не нужны.
ADMIN_USER_ID=

# Пример: SUPPORT_USERNAME=your_support_username
SUPPORT_USERNAME=

# 2. Fragment API
FRAGMENT_API_URL=https://api-fragment.duckdns.org

# Рекомендуемый режим: kyc
# kyc стабильнее, потому что API использует вашу авторизованную Fragment-сессию.
# no_kyc оставлен только для быстрого теста и может чаще ловить ограничения/ошибки.
FRAGMENT_API_MODE=kyc

# 24 слова кошелька, с которого Fragment будет покупать Stars.
# Этот же кошелек должен быть подключен в Fragment перед снятием cookies для KYC.
# Пример: FRAGMENT_WALLET_MNEMONIC=word_01 word_02 ... word_24
FRAGMENT_WALLET_MNEMONIC=

# Только для FRAGMENT_API_MODE=kyc.
# Это Base64 от JSON cookies Fragment.
# Пример исходного JSON перед Base64:
# {"stel_token":"<stel_token>","stel_ton_token":"<stel_ton_token>","stel_ssid":"<stel_ssid>","stel_both":"<stel_both>"}
# Пример команды:
# printf '%s' '{"stel_token":"...","stel_ton_token":"...","stel_ssid":"...","stel_both":"..."}' | base64
FRAGMENT_COOKIES_BASE64=

# Демо-цена одной Star в USD до комиссии Fragment.
# Если ваша API/экономика отличается, поменяйте это значение.
FRAGMENT_STAR_BASE_USD=0.015

# 3. TON payment receiving
# Пример: TON_WALLET_ADDRESS=UQ...your_ton_wallet_address
TON_WALLET_ADDRESS=

# Опционально: TonCenter API key. Старое имя TONAPI_KEY тоже поддерживается.
# Пример: TONCENTER_API_KEY=<toncenter_api_key>
TONCENTER_API_KEY=

# 4. Pricing
MIN_STARS_AMOUNT=50
MAX_STARS_AMOUNT=50000
ORDER_TIMEOUT_MINUTES=15
SERVICE_COMMISSION_PERCENT=3

# Используется только для FreeKassa счета в RUB.
# Для демо можно поставить фиксированный курс вручную.
USD_RUB_RATE=100

# 5. The only acquiring provider in this demo: FreeKassa
ENABLE_FREEKASSA=false

# Пример: FREEKASSA_API_KEY=<freekassa_api_key>
FREEKASSA_API_KEY=

# Пример: FREEKASSA_SHOP_ID=12345
FREEKASSA_SHOP_ID=0

# FreeKassa payment method:
# 44 = SBP QR, 36 = bank cards RF, 43 = SberPay
FREEKASSA_METHOD=44

# FreeKassa API требует IP покупателя. В простом Telegram polling-боте реального IP нет,
# поэтому укажите разрешенный/статичный IP, если ваш кабинет FreeKassa это требует.
FREEKASSA_CUSTOMER_IP=127.0.0.1

# 6. Local app
DATABASE_PATH=stars_bot.db
BOT_VERSION=2.0-demo
